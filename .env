# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gachabeats
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=gachabeats

# Session Configuration
SESSION_SECRET=sK9mP3nQ7wR2xV8cF4hJ6bN1aL5zT0yU9iO3pA7sD2fG6hK1mN4qW8eR5tY2uI0o

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:5000

# Security
BCRYPT_SALT_ROUNDS=12

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=15000
WS_MAX_MESSAGE_SIZE=1048576

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# Feature Flags
ENABLE_GACHA=true
ENABLE_DAW=true
ENABLE_MULTIPLAYER=true
