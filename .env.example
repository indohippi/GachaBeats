# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/gachabeats

# Session Configuration
SESSION_SECRET=your-super-secret-session-key-change-this-in-production
NODE_ENV=development

# Server Configuration
PORT=5000

# CORS Configuration (comma-separated URLs for multiple origins)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Security
# Bcrypt salt rounds (10-12 recommended, higher = more secure but slower)
BCRYPT_SALT_ROUNDS=12

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=15000
WS_MAX_MESSAGE_SIZE=1048576

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Payment Configuration (Stripe)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# Feature Flags
ENABLE_GACHA=true
ENABLE_DAW=true
ENABLE_MULTIPLAYER=true
